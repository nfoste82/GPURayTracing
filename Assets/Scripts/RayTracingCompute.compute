uint Hash(uint value)
{
    value ^= value >> 16;
    value *= 0x7feb352d;
    value ^= value >> 15;
    value *= 0x846ca68b;
    value ^= value >> 16;
    return value;
}

uint CreateRngState(uint2 pixel, uint sampleIndex)
{
    uint state = _Seed;
    state ^= pixel.x * 1973u;
    state ^= pixel.y * 9277u;
    state ^= sampleIndex * 26699u;
    return Hash(state);
}

float rand(inout uint rngState)
{
    rngState = Hash(rngState);
    return (rngState & 0x00ffffff) / 16777216.0f;
}

